# 生产环境配置文件
# 复制此文件为 .env.prod 并填写实际值

# 数据库配置
DB_ROOT_PASSWORD=your_strong_root_password_here
DB_USERNAME=myJavaProject_user
DB_PASSWORD=your_strong_db_password_here

# Redis配置（如果使用外部Redis）
REDIS_PASSWORD=

# 应用配置
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=7002
LOG_FILE=/app/logs/application.log

# 日志配置
LOGGING_LEVEL_COM_EXAMPLE=INFO
LOGGING_FILE_NAME=/app/logs/myJavaProject.log

# 监控配置
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized

# 安全配置（生产环境必须配置）
# JWT配置
JWT_SECRET=your_256_bit_jwt_secret_key_here
JWT_EXPIRATION=86400000

# CORS配置
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 文件上传配置
FILE_UPLOAD_MAX_SIZE=10MB
FILE_UPLOAD_MAX_FILES=5

# OSS配置（生产环境必填）
OSS_ENDPOINT=https://oss-cn-your-region.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_URL_PREFIX=https://your-bucket.oss-cn-your-region.aliyuncs.com/

# 缓存配置
CACHE_TYPE=redis
CACHE_TTL=3600000
